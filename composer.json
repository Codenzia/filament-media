{
    "name": "codenzia/filament-media",
    "description": "This is my package filament-media",
    "keywords": [
        "codenzia",
        "laravel",
        "filament-media"
    ],
    "homepage": "https://github.com/codenzia/filament-media",
    "support": {
        "issues": "https://github.com/codenzia/filament-media/issues",
        "source": "https://github.com/codenzia/filament-media"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Codenzia",
            "email": "mahmoudsehsah36@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "filament/filament": "^4.0",
        "spatie/laravel-package-tools": "^1.17.0"
    },
    "require-dev": {
        "nunomaduro/collision": "^7.9",
        "orchestra/testbench": "^8.0",
        "pestphp/pest": "^2.1",
        "pestphp/pest-plugin-arch": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Codenzia\\FilamentMedia\\": "src/",
            "Codenzia\\FilamentMedia\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Codenzia\\FilamentMedia\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Codenzia\\FilamentMedia\\FilamentMediaServiceProvider"
            ],
            "aliases": {
                "FilamentMedia": "Codenzia\\FilamentMedia\\Facades\\FilamentMedia"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
