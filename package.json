{
    "private": true,
    "type": "module",
    "scripts": {
        "dev:styles": "npx tailwindcss -i resources/css/filament-media.css -o resources/dist/filament-media.css --postcss --watch",
        "dev:scripts": "node bin/build.js --dev",
        "build:styles": "npx tailwindcss -i resources/css/filament-media.css -o resources/dist/filament-media.css --postcss --minify",
        "build:scripts": "node bin/build.js",
        "dev": "npm-run-all --parallel dev:*",
        "build": "npm-run-all build:*"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.0",
        "@tailwindcss/postcss": "^4.0",
        "esbuild": "^0.27.2",
        "npm-run-all": "^4.1.5",
        "postcss": "^8.4.26",
        "prettier": "^2.7.1",
        "tailwindcss": "^4.0"
    },
    "dependencies": {
        "cropperjs": "^2.1.0"
    }
}
